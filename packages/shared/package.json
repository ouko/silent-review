    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "^5.16.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "prisma": "^5.16.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
